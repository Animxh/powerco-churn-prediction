# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.env
.venv
ENV/

# ── Jupyter Notebooks ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files (too large / sensitive for version control) ───────────────────
data/*.csv
data/*.xlsx
data/*.parquet
data/*.json
!data/README.md

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs & temp ──────────────────────────────────────────────────────────────
*.log
*.tmp
.cache/
